PORT=3001
# Optional: comma-separated CORS origins
# CORS_ORIGIN=https://www.yoursite.com

MAIL_TO=sahajindiallp@gmail.com
# MAIL_FROM=Sahaj Construction <noreply@your-verified-domain.com>

# --- Brevo (Sendinblue) SMTP ---
# Dashboard → SMTP & API → SMTP: copy the server, login, and SMTP key.
SMTP_HOST=smtp-relay.brevo.com
# Use 587 or 2525 with STARTTLS (do NOT set legacy SMTP_SECURE=true for these ports).
SMTP_PORT=587
# Ignored for ports 587/2525/465 (code picks the correct TLS mode to avoid SSL errors).

SMTP_USER=your-brevo-login-email
SMTP_PASS=your-brevo-smtp-key

# Optional Gmail-style block (not used with Brevo):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=...
# SMTP_PASS=app-password

# Optional: longer timeouts (ms)
# SMTP_CONNECTION_TIMEOUT_MS=90000
# SMTP_FORCE_IPV4=true

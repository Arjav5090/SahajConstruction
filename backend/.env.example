# --- Server ---
# Port the API listens on (default 3001). Vite proxies /api here in dev.
PORT=3001

# Optional: allowed browser origins for CORS, comma-separated.
# Example: http://localhost:5173,https://www.sahajconstruction.in
# Leave unset in dev to allow any origin.
# CORS_ORIGIN=

# --- Where emails go ---
# Inbox that receives contact + careers submissions (your real address).
MAIL_TO=you@gmail.com

# Optional "From" header. If omitted, uses: Sahaj Construction Website <SMTP_USER>
# MAIL_FROM=Sahaj Construction <noreply@yourdomain.com>

# --- SMTP (Gmail example) ---
# Outgoing mail server hostname.
SMTP_HOST=smtp.gmail.com

# Usually 587 (STARTTLS) or 465 (SSL). Match SMTP_SECURE below.
SMTP_PORT=587

# false = STARTTLS on 587; true = SSL on 465
SMTP_SECURE=false

# The mailbox that logs in to SMTP (often same as MAIL_TO for Gmail).
SMTP_USER=you@gmail.com

# App password (Gmail: Google Account → Security → 2-Step Verification → App passwords).
# Not your normal Gmail password if 2FA is on.
SMTP_PASS=xxxx xxxx xxxx xxxx

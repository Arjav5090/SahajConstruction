PORT=3001
# Optional: comma-separated origins for CORS
# CORS_ORIGIN=https://www.yoursite.com

# --- Inbox (required for all transports) ---
MAIL_TO=you@gmail.com

# =============================================================================
# PRODUCTION (Render, Railway, etc.) — use HTTPS email API
# Render blocks outbound SMTP (Gmail smtp.gmail.com:587 times out with ETIMEDOUT).
# =============================================================================
# Get a key at https://resend.com — free tier available.
# RESEND_API_KEY=re_xxxxxxxx
# "From" must be a verified sender in Resend (use onboarding@resend.dev for tests).
# MAIL_FROM=Sahaj Construction <onboarding@resend.dev>

# =============================================================================
# LOCAL / VPS with open SMTP — optional if not using Resend
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=app-password
# MAIL_FROM is optional for SMTP (defaults to SMTP_USER)

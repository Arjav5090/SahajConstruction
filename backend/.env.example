PORT=3001
# Optional: comma-separated CORS origins
# CORS_ORIGIN=https://www.yoursite.com

# Inbox that receives contact + careers emails
MAIL_TO=sahajindiallp@gmail.com

# Optional "From" line (defaults to Sahaj Construction Website <SMTP_USER>)
# MAIL_FROM=Sahaj Construction <sahajindiallp@gmail.com>

# --- Gmail (use an App Password if 2FA is on) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Or try SSL on 465: SMTP_PORT=465 and SMTP_SECURE=true

SMTP_USER=sahajindiallp@gmail.com
SMTP_PASS=

# Optional: longer waits if the server is slow (milliseconds)
# SMTP_CONNECTION_TIMEOUT_MS=90000
# SMTP_GREETING_TIMEOUT_MS=45000
# SMTP_SOCKET_TIMEOUT_MS=120000

# Optional: set true if connections hang (broken IPv6 to Gmail)
# SMTP_FORCE_IPV4=true

# Note: Some PaaS hosts (e.g. Render) block outbound SMTP — timeouts then are not fixable
# by these settings; run the API on a VPS or a host that allows SMTP.
